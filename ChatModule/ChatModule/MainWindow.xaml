<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ChatModule.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ChatModule"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ChatModule">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#17153B">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2E236C" BorderBrush="#433D8B" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#433D8B" Padding="16,14" BorderBrush="#433D8B" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock
                            Text="WhatsApp-style Shell"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                            FontSize="21"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Text="{x:Bind ViewModel.CurrentUsername, Mode=OneWay}"
                            Foreground="#C8ACD6"
                            Opacity="0.8"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                            FontSize="12" />
                    </StackPanel>
                </Border>

                <Button
                    Grid.Row="1"
                    Content="Conversations"
                    Command="{x:Bind ViewModel.GoToConversationsCommand}"
                    Background="#2E236C"
                    Foreground="#C8ACD6"
                    BorderBrush="#433D8B"
                    BorderThickness="0,0,0,1"
                    CornerRadius="0"
                    Padding="16,14"
                    HorizontalAlignment="Stretch"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    HorizontalContentAlignment="Left" />

                <Button
                    Grid.Row="2"
                    Content="Friends"
                    Command="{x:Bind ViewModel.GoToFriendsCommand}"
                    Background="#2E236C"
                    Foreground="#C8ACD6"
                    BorderBrush="#433D8B"
                    BorderThickness="0,0,0,1"
                    CornerRadius="0"
                    Padding="16,14"
                    HorizontalAlignment="Stretch"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    HorizontalContentAlignment="Left" />

                <Button
                    Grid.Row="3"
                    Content="Profile"
                    Command="{x:Bind ViewModel.GoToProfileCommand}"
                    Background="#2E236C"
                    Foreground="#C8ACD6"
                    BorderBrush="#433D8B"
                    BorderThickness="0,0,0,1"
                    CornerRadius="0"
                    Padding="16,14"
                    HorizontalAlignment="Stretch"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    HorizontalContentAlignment="Left" />

                <Button
                    Grid.Row="5"
                    Content="Logout"
                    Command="{x:Bind ViewModel.LogoutCommand}"
                    Background="#17153B"
                    Foreground="#C8ACD6"
                    BorderBrush="#433D8B"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,11"
                    HorizontalAlignment="Stretch"
                    Margin="12"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#17153B" Margin="0">
            <Border Background="#17153B" CornerRadius="0" BorderThickness="0" Padding="0">
                <ContentControl x:Name="CurrentPageHost" />
            </Border>
        </Grid>
    </Grid>
</Window>
