<Window
    x:Class="ChatModule.src.views.ForgotPasswordWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Forgot Password">

    <Grid Background="#17153B">
        <Border
            Width="440"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#2E236C"
            CornerRadius="10"
            Padding="24">
            <StackPanel Spacing="12">
                <TextBlock
                    Text="Reset Password"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="24"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="Enter your email and choose a new password."
                    Foreground="#C8ACD6"
                    Opacity="0.8"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    TextWrapping="Wrap" />

                <TextBox
                    PlaceholderText="Email"
                    Text="{x:Bind ViewModel.Email, Mode=TwoWay}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="10,6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <PasswordBox
                    x:Name="NewPasswordBox"
                    PlaceholderText="New Password"
                    PasswordChanged="NewPasswordBox_PasswordChanged"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="10,6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <Button
                    Content="Submit"
                    Command="{x:Bind ViewModel.SubmitCommand}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="0,10"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />

                <HyperlinkButton
                    Content="Back to Login"
                    HorizontalAlignment="Left"
                    Command="{x:Bind ViewModel.BackToLoginCommand}"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <TextBlock
                    Foreground="#FF8A8A"
                    TextWrapping="Wrap"
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <TextBlock
                    Foreground="#7EF7B8"
                    TextWrapping="Wrap"
                    Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
