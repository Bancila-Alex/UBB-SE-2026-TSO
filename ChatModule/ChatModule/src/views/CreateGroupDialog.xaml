<ContentDialog
    x:Class="ChatModule.src.views.CreateGroupDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:models="using:ChatModule.Models"
    x:Name="RootDialog"
    Title="Create Group"
    Background="#17153B">

    <ContentDialog.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="560" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Padding="4,4,4,8">
            <TextBlock
                Text="New Group"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                FontSize="22"
                FontWeight="SemiBold" />

            <TextBox
                Header="Group name"
                Text="{x:Bind ViewModel.GroupName, Mode=TwoWay}"
                PlaceholderText="Give your group a name"
                Background="#2E236C"
                Foreground="#C8ACD6"
                BorderBrush="#433D8B"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

            <TextBlock
                Text="Group icon"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    Text="{x:Bind ViewModel.IconUrl, Mode=OneWay}"
                    PlaceholderText="No icon selected"
                    IsReadOnly="True"
                    Background="#2E236C"
                    Foreground="#C8ACD6"
                    BorderBrush="#433D8B"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <Button
                    Grid.Column="1"
                    Content="Browse"
                    Click="OnPickIconClicked"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    Padding="12,6"
                    CornerRadius="4" />
            </Grid>

            <TextBlock
                Text="Add members"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                FontSize="16"
                FontWeight="SemiBold" />

            <TextBox
                Text="{x:Bind ViewModel.MemberSearchQuery, Mode=TwoWay}"
                PlaceholderText="Search usernames"
                Background="#2E236C"
                Foreground="#C8ACD6"
                BorderBrush="#433D8B"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

            <TextBlock
                Text="Search results"
                Foreground="#C8ACD6"
                Opacity="0.85"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

            <ListView
                ItemsSource="{x:Bind ViewModel.MemberSearchResults, Mode=OneWay}"
                SelectionMode="None"
                MaxHeight="180"
                Background="#2E236C"
                BorderBrush="#433D8B"
                BorderThickness="1">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Text="{Binding Username}"
                                Foreground="#C8ACD6"
                                FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                FontSize="14"
                                VerticalAlignment="Center" />
                            <Button
                                Grid.Column="1"
                                Content="Add"
                                Command="{Binding ElementName=RootDialog, Path=ViewModel.AddMemberCommand}"
                                CommandParameter="{Binding}"
                                Background="#433D8B"
                                Foreground="#C8ACD6"
                                Padding="10,4"
                                CornerRadius="4" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                Text="Selected members"
                Foreground="#C8ACD6"
                Opacity="0.85"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

            <ListView
                ItemsSource="{x:Bind ViewModel.SelectedMembers, Mode=OneWay}"
                SelectionMode="None"
                MaxHeight="180"
                Background="#2E236C"
                BorderBrush="#433D8B"
                BorderThickness="1">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Text="{Binding Username}"
                                Foreground="#C8ACD6"
                                FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                FontSize="14"
                                VerticalAlignment="Center" />
                            <Button
                                Grid.Column="1"
                                Content="Remove"
                                Command="{Binding ElementName=RootDialog, Path=ViewModel.RemoveMemberCommand}"
                                CommandParameter="{Binding}"
                                Background="#2E236C"
                                Foreground="#C8ACD6"
                                BorderBrush="#433D8B"
                                BorderThickness="1"
                                Padding="10,4"
                                CornerRadius="4" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibility}}"
                Foreground="#FFB4AB"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    Content="Cancel"
                    Command="{x:Bind ViewModel.CancelCommand}"
                    Background="#2E236C"
                    Foreground="#C8ACD6"
                    BorderBrush="#433D8B"
                    BorderThickness="1"
                    Margin="0,0,8,0"
                    Padding="14,8"
                    CornerRadius="4" />

                <Button
                    Grid.Column="2"
                    Content="Create"
                    Command="{x:Bind ViewModel.CreateCommand}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    Padding="14,8"
                    CornerRadius="4" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
