<Window
    x:Class="ChatModule.src.views.RegisterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Register">

    <Grid Background="#17153B">
        <Border
            Width="440"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#2E236C"
            CornerRadius="10"
            Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Create Account"
                        Foreground="#C8ACD6"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                        FontSize="24"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="Fill in your details to register."
                        Foreground="#C8ACD6"
                        Opacity="0.8"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                        TextWrapping="Wrap" />

                    <TextBox
                        PlaceholderText="Username"
                        Text="{x:Bind ViewModel.Username, Mode=TwoWay}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="10,6"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <TextBox
                        PlaceholderText="Email"
                        Text="{x:Bind ViewModel.Email, Mode=TwoWay}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="10,6"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <PasswordBox
                        x:Name="PasswordBox"
                        PlaceholderText="Password"
                        PasswordChanged="PasswordBox_PasswordChanged"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="10,6"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <TextBox
                        PlaceholderText="Phone"
                        Text="{x:Bind ViewModel.Phone, Mode=TwoWay}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="10,6"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <DatePicker
                        Header="Birthday"
                        Date="{x:Bind BirthdayDate, Mode=TwoWay}"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <Button
                        Content="Register"
                        Command="{x:Bind ViewModel.RegisterCommand}"
                        IsEnabled="{x:Bind IsNotLoading(ViewModel.IsLoading), Mode=OneWay}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="0,10"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />

                    <HyperlinkButton
                        Content="Back to Login"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.BackToLoginCommand}"
                        Foreground="#C8ACD6"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <TextBlock
                        Foreground="#FF8A8A"
                        TextWrapping="Wrap"
                        Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        Visibility="{x:Bind ErrorMessageVisibility(ViewModel.ErrorMessage), Mode=OneWay}"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <ProgressRing
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Center"
                        Foreground="#C8ACD6" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
