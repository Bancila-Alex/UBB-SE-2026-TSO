<UserControl
    x:Class="ChatModule.src.views.MessageSearchPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:models="using:ChatModule.Models"
    x:Name="RootControl">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B" Padding="12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="Search Messages"
            Foreground="#C8ACD6"
            FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
            FontSize="20"
            FontWeight="SemiBold" />

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                Text="{x:Bind ViewModel.Query, Mode=TwoWay}"
                PlaceholderText="Search in conversation"
                Background="#2E236C"
                Foreground="#C8ACD6"
                BorderBrush="#433D8B"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

            <Button
                Grid.Column="1"
                Content="Search"
                Command="{x:Bind ViewModel.SearchCommand}"
                Background="#433D8B"
                Foreground="#C8ACD6"
                Padding="12,6"
                CornerRadius="4" />
        </Grid>

        <ProgressRing
            Grid.Row="2"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
            Width="28"
            Height="28"
            Foreground="#C8ACD6"
            HorizontalAlignment="Left" />

        <Grid Grid.Row="3">
            <ListBox
                ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
                Background="#2E236C"
                BorderBrush="#433D8B"
                BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="10,8" Background="#17153B" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock
                                            Text="{Binding SenderUsername}"
                                            Foreground="#C8ACD6"
                                            FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                            FontSize="13"
                                            FontWeight="SemiBold" />
                                        <TextBlock
                                            Text="{Binding CreatedAt}"
                                            Foreground="#C8ACD6"
                                            Opacity="0.75"
                                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                            FontSize="11" />
                                    </StackPanel>
                                    <TextBlock
                                        Text="{Binding Content}"
                                        Foreground="#C8ACD6"
                                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                        FontSize="13"
                                        MaxLines="2"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Content="Go"
                                    Command="{Binding ElementName=RootControl, Path=ViewModel.JumpToMessageCommand}"
                                    CommandParameter="{Binding Id}"
                                    Background="#433D8B"
                                    Foreground="#C8ACD6"
                                    Padding="10,4"
                                    CornerRadius="4"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock
                Text="{x:Bind ViewModel.NoResultsMessage, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.NoResultsMessage, Mode=OneWay, Converter={StaticResource NullToVisibility}}"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                Opacity="0.8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Grid>

        <Button
            Grid.Row="4"
            Content="Close"
            Command="{x:Bind ViewModel.CloseCommand}"
            HorizontalAlignment="Right"
            Background="#2E236C"
            Foreground="#C8ACD6"
            BorderBrush="#433D8B"
            BorderThickness="1"
            Padding="12,6"
            CornerRadius="4" />
    </Grid>
</UserControl>
