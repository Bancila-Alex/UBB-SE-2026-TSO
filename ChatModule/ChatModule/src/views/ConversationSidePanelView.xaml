<UserControl
    x:Class="ChatModule.src.views.ConversationSidePanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    x:Name="RootControl">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Border
        HorizontalAlignment="Stretch"
        Background="#17153B"
        BorderBrush="#2E236C"
        BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2E236C" Padding="10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.PanelTitle, Mode=OneWay}"
                        Foreground="#C8ACD6"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                        FontSize="16"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.IsPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                    <Button
                        Grid.Column="1"
                        Content="{x:Bind ViewModel.TogglePanelIcon, Mode=OneWay}"
                        Command="{x:Bind ViewModel.TogglePanelCommand}"
                        Background="Transparent"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        Padding="8,2"
                        FontSize="14"
                        Visibility="{x:Bind ViewModel.IsPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </Border>

            <Border
                Grid.RowSpan="2"
                Width="44"
                HorizontalAlignment="Stretch"
                Background="#2E236C"
                Visibility="{x:Bind ViewModel.IsPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <Button
                    Content="{x:Bind ViewModel.TogglePanelIcon, Mode=OneWay}"
                    Command="{x:Bind ViewModel.TogglePanelCommand}"
                    Background="Transparent"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Padding="8,10"
                    FontSize="14" />
            </Border>

            <ContentControl
                Grid.Row="1"
                x:Name="PanelContentHost"
                Visibility="{x:Bind ViewModel.IsPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
        </Grid>
    </Border>
</UserControl>
