<UserControl
    x:Class="ChatModule.src.views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:models="using:ChatModule.Models"
    x:Name="RootControl">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <DataTemplate x:Key="MessageItemTemplate">
            <Grid Margin="0,4" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="36"
                    Height="36"
                    Background="#433D8B"
                    CornerRadius="18"
                    VerticalAlignment="Top">
                    <TextBlock
                        Text="{Binding UserId}"
                        FontSize="0.1"
                        Opacity="0" />
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="10,8"
                    Background="#2E236C"
                    CornerRadius="10">
                    <StackPanel Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="{Binding UserId}"
                                Foreground="#C8ACD6"
                                FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                FontSize="13"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                <TextBlock
                                    Text="{Binding CreatedAt}"
                                    Foreground="#C8ACD6"
                                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                    FontSize="11"
                                    Opacity="0.85" />
                                <TextBlock
                                    Text="edited"
                                    Foreground="#C8ACD6"
                                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                    FontSize="11"
                                    FontStyle="Italic"
                                    Visibility="{Binding IsEdited, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Text="{Binding Content}"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                            FontSize="14"
                            TextWrapping="Wrap"
                            Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />

                        <TextBlock
                            Text="This message was deleted"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                            FontSize="14"
                            FontStyle="Italic"
                            Opacity="0.8"
                            Visibility="{Binding IsDeleted, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E236C" Padding="16,12">
            <TextBlock
                Text="{x:Bind ViewModel.ConversationTitle, Mode=OneWay}"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                FontSize="18"
                FontWeight="SemiBold" />
        </Border>

        <!-- Pinned Message -->
        <Border
            Grid.Row="0"
            Background="#433D8B"
            Padding="12,6"
            Margin="0,44,0,0"
            Visibility="{x:Bind ViewModel.PinnedMessage, Mode=OneWay, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock
                    Text="📌"
                    FontSize="13"
                    VerticalAlignment="Center" />
                <TextBlock
                    Text="{x:Bind ViewModel.PinnedMessage.Content, Mode=OneWay}"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="13"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                    VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Messages List -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
            ItemTemplate="{StaticResource MessageItemTemplate}"
            Background="Transparent"
            Padding="8"
            SelectionMode="None" />

        <!-- Reply Preview Bar -->
        <Border
            Grid.Row="2"
            Background="#2E236C"
            Padding="12,6"
            Visibility="{x:Bind ViewModel.ReplyingTo, Mode=OneWay, Converter={StaticResource NullToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock
                        Text="Replying to:"
                        Foreground="#C8ACD6"
                        FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                        FontSize="11"
                        Opacity="0.7" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ReplyingTo.Content, Mode=OneWay}"
                        Foreground="#C8ACD6"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                        FontSize="13"
                        MaxLines="1"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Content="✕"
                    Command="{x:Bind ViewModel.CancelReplyCommand}"
                    Background="Transparent"
                    Foreground="#C8ACD6"
                    BorderThickness="0" />
            </Grid>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="3" Background="#2E236C" Padding="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                Text="{x:Bind ViewModel.MessageInput, Mode=TwoWay}"
                PlaceholderText="Type a message..."
                Background="#433D8B"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                FontSize="14"
                BorderThickness="0"
                CornerRadius="4"
                Padding="10,8"
                IsEnabled="{x:Bind ViewModel.IsInputDisabled, Mode=OneWay}" />
            <Button
                Grid.Column="1"
                Content="Send"
                Command="{x:Bind ViewModel.SendCommand}"
                Background="#433D8B"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                Margin="6,0,0,0"
                Padding="16,8"
                CornerRadius="4" />
        </Grid>
    </Grid>
</UserControl>
