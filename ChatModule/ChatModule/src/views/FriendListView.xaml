<UserControl
    x:Class="ChatModule.src.views.FriendListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:viewModels="using:ChatModule.src.view_models"
    x:Name="RootControl">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2E236C" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="Friends"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="18"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />

                <Button
                    Grid.Column="1"
                    Content="Refresh"
                    Command="{x:Bind ViewModel.LoadCommand}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="12,6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="8">
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Width="40"
                Height="40"
                Foreground="#433D8B"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <ListView
                ItemsSource="{x:Bind ViewModel.FriendItems, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.ShowFriendList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Background="Transparent"
                Padding="0"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:FriendListItemViewModel">
                        <Border
                            Background="#2E236C"
                            CornerRadius="8"
                            Margin="0,4"
                            Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid
                                    Grid.Column="0"
                                    Width="44"
                                    Height="44"
                                    Margin="0,0,12,0">
                                    <Ellipse Width="44" Height="44" Fill="#433D8B" />
                                    <TextBlock
                                        Text="{x:Bind AvatarInitial}"
                                        Foreground="#C8ACD6"
                                        FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                                    <Grid
                                        Width="12"
                                        Height="12"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom">
                                        <Ellipse Fill="#17153B" />
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Fill="#57F287"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind IsOnline, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Fill="#FEE75C"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Fill="#747F8D"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind IsOffline, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Grid>

                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock
                                            Text="{x:Bind Username}"
                                            Foreground="#C8ACD6"
                                            FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Text="🎂"
                                            FontSize="14"
                                            Visibility="{x:Bind IsBirthdayToday, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>

                                    <TextBlock
                                        Text="{x:Bind StatusLabel}"
                                        Foreground="#C8ACD6"
                                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                        FontSize="12"
                                        Opacity="0.8" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    VerticalAlignment="Center">
                                    <Button
                                        Content="Open DM"
                                        Command="{Binding ElementName=RootControl, Path=ViewModel.OpenDmCommand}"
                                        CommandParameter="{x:Bind Id}"
                                        Background="#433D8B"
                                        Foreground="#C8ACD6"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Padding="10,6"
                                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />

                                    <Button
                                        Content="Profile"
                                        Command="{Binding ElementName=RootControl, Path=ViewModel.ViewProfileCommand}"
                                        CommandParameter="{x:Bind Id}"
                                        Background="#2E236C"
                                        Foreground="#C8ACD6"
                                        BorderBrush="#433D8B"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,6"
                                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />

                                    <Button
                                        Content="Remove"
                                        Command="{Binding ElementName=RootControl, Path=ViewModel.RemoveFriendCommand}"
                                        CommandParameter="{x:Bind Id}"
                                        Background="#2E236C"
                                        Foreground="#FFB4AB"
                                        BorderBrush="#433D8B"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,6"
                                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock
                    Text="No friends found"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="15"
                    Opacity="0.7"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Accept requests to start chatting"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="13"
                    Opacity="0.55"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
