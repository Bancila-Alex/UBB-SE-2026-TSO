<UserControl
    x:Class="ChatModule.src.views.FriendListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    x:Name="RootControl">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2E236C" Padding="18,16">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="Friends"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="18"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />

                <StackPanel
                    Grid.Row="0"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Button
                        Content="Requests"
                        Command="{Binding OpenRequestsCommand}"
                        Background="#2E236C"
                        Foreground="#C8ACD6"
                        BorderBrush="#433D8B"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="14,8"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />

                    <Button
                        Content="Refresh"
                        Command="{Binding LoadCommand}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="14,8"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />
                </StackPanel>

                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnSpacing="10" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        Grid.Column="0"
                        Text="{Binding FriendUsernameInput, Mode=TwoWay}"
                        PlaceholderText="Add friend by username"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="12,8"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <Button
                        Grid.Column="1"
                        Content="Add"
                        Command="{Binding SendFriendRequestCommand}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="14,8"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />
                </Grid>

                <TextBlock
                    Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Text="{Binding FriendActionMessage}"
                    Foreground="#C8ACD6"
                    Opacity="0.85"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="12" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="10">
            <ProgressRing
                IsActive="{Binding IsLoading}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Width="40"
                Height="40"
                Foreground="#433D8B"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <ListView
                x:Name="FriendList"
                ItemsSource="{Binding FriendItems}"
                Background="Transparent"
                SelectionMode="None"
                Visibility="{Binding ShowFriendList, Converter={StaticResource BoolToVisibility}}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="#2E236C"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Width="40" Height="40">
                                    <Ellipse Fill="#433D8B" />
                                    <TextBlock
                                        Text="{Binding AvatarInitial}"
                                        Foreground="#C8ACD6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                        FontSize="16"
                                        FontWeight="SemiBold" />
                                </Grid>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock
                                        Text="{Binding Username}"
                                        Foreground="#C8ACD6"
                                        FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                        FontSize="14"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding StatusLabel}"
                                        Foreground="#C8ACD6"
                                        Opacity="0.7"
                                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                        FontSize="12" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                    <Button
                                        Content="Profile"
                                        Click="OnViewProfileClick"
                                        Tag="{Binding Id}"
                                        Background="#2E236C"
                                        Foreground="#C8ACD6"
                                        BorderBrush="#433D8B"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,4" />

                                    <Button
                                        Content="DM"
                                        Click="OnOpenDmClick"
                                        Tag="{Binding Id}"
                                        Background="#433D8B"
                                        Foreground="#C8ACD6"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Padding="10,4" />

                                    <Button
                                        Content="Remove"
                                        Click="OnRemoveFriendClick"
                                        Tag="{Binding Id}"
                                        Background="Transparent"
                                        Foreground="#C8ACD6"
                                        BorderBrush="#433D8B"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,4" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibility}}">
                <TextBlock
                    Text="No friends found"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="15"
                    Opacity="0.7"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Accept requests to start chatting"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="13"
                    Opacity="0.55"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
