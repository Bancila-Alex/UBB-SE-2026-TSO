<UserControl
    x:Class="ChatModule.src.views.FriendListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    x:Name="RootControl">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2E236C" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="Friends"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="18"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />

                <Button
                    Grid.Column="1"
                    Content="Refresh"
                    Command="{x:Bind ViewModel.LoadCommand}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="12,6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="8">
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Width="40"
                Height="40"
                Foreground="#433D8B"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <TextBlock Text="Friends list preview" Foreground="#C8ACD6" FontSize="14"/>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock
                    Text="No friends found"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="15"
                    Opacity="0.7"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Accept requests to start chatting"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="13"
                    Opacity="0.55"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
