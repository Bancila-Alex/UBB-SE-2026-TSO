<UserControl
    x:Class="ChatModule.src.views.ConversationListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:domain="using:ChatModule.src.domain"
    x:Name="RootControl">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:StringFallbackConverter x:Key="StringFallback" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E236C" Padding="16,12">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="Conversations"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="20"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Content="New Group"
                        Command="{x:Bind ViewModel.NewGroupCommand}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="12,6"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />
                    <Button
                        Content="New DM"
                        Command="{x:Bind ViewModel.NewDmCommand}"
                        Background="#2E236C"
                        Foreground="#C8ACD6"
                        BorderBrush="#433D8B"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,6"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab bar -->
        <Border Grid.Row="1" Background="#2E236C" Padding="12,10">
            <ScrollViewer
                HorizontalScrollBarVisibility="Auto"
                HorizontalScrollMode="Auto"
                VerticalScrollBarVisibility="Disabled"
                VerticalScrollMode="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel Spacing="4">
                        <Button
                            Content="All"
                            Command="{x:Bind ViewModel.SwitchTabCommand}"
                            CommandParameter="All"
                            Background="Transparent"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            Padding="10,4"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
                        <Rectangle
                            Height="2"
                            Fill="#C8ACD6"
                            Visibility="{x:Bind ViewModel.IsAllTabActive, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Button
                            Content="Direct Messages"
                            Command="{x:Bind ViewModel.SwitchTabCommand}"
                            CommandParameter="Direct Messages"
                            Background="Transparent"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            Padding="10,4"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
                        <Rectangle
                            Height="2"
                            Fill="#C8ACD6"
                            Visibility="{x:Bind ViewModel.IsDirectMessagesTabActive, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Button
                            Content="Groups"
                            Command="{x:Bind ViewModel.SwitchTabCommand}"
                            CommandParameter="Groups"
                            Background="Transparent"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            Padding="10,4"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
                        <Rectangle
                            Height="2"
                            Fill="#C8ACD6"
                            Visibility="{x:Bind ViewModel.IsGroupsTabActive, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Button
                            Content="Favorites"
                            Command="{x:Bind ViewModel.SwitchTabCommand}"
                            CommandParameter="Favorites"
                            Background="Transparent"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            Padding="10,4"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
                        <Rectangle
                            Height="2"
                            Fill="#C8ACD6"
                            Visibility="{x:Bind ViewModel.IsFavoritesTabActive, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Button
                            Content="Unread"
                            Command="{x:Bind ViewModel.SwitchTabCommand}"
                            CommandParameter="Unread"
                            Background="Transparent"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            Padding="10,4"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
                        <Rectangle
                            Height="2"
                            Fill="#C8ACD6"
                            Visibility="{x:Bind ViewModel.IsUnreadTabActive, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Search box -->
        <Border Grid.Row="2" Background="#2E236C" Padding="12,10" Margin="0,1,0,0">
            <TextBox
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}"
                PlaceholderText="Search conversations"
                Background="#433D8B"
                Foreground="#C8ACD6"
                BorderThickness="0"
                CornerRadius="4"
                Padding="10,6"
                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
        </Border>

        <!-- Conversation list -->
        <Grid Grid.Row="3">

            <!-- Loading indicator -->
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Foreground="#433D8B"
                Width="36"
                Height="36"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <!-- Conversations list -->
            <ListView
                ItemsSource="{x:Bind ViewModel.Conversations, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedConversation, Mode=TwoWay}"
                Background="Transparent"
                Padding="6,4"
                SelectionMode="Single"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="domain:Conversation">
                        <Border
                            Background="#2E236C"
                            CornerRadius="6"
                            Padding="10,10">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <Grid Grid.Column="0" Width="42" Height="42">
                                    <Ellipse Fill="#433D8B" />
                                    <Image
                                        Source="{x:Bind IconUrl}"
                                        Stretch="UniformToFill"
                                        Visibility="{x:Bind IconUrl, Converter={StaticResource NullToVisibility}}" />
                                </Grid>

                                <!-- Title and type label -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                    <TextBlock
                                        Text="{x:Bind Title, Converter={StaticResource StringFallback}, ConverterParameter='Direct Message'}"
                                        Foreground="#C8ACD6"
                                        FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                        FontSize="14"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="1" />
                                    <TextBlock
                                        Text="{x:Bind Type}"
                                        Foreground="#C8ACD6"
                                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                        FontSize="11"
                                        Opacity="0.55" />
                                </StackPanel>

                                <!-- Action buttons -->
                                <StackPanel
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                                    <Button
                                        Content="★"
                                        ToolTipService.ToolTip="Toggle Favourite"
                                        Command="{Binding ElementName=RootControl, Path=ViewModel.ToggleFavouriteCommand}"
                                        CommandParameter="{x:Bind Id}"
                                        Background="Transparent"
                                        Foreground="#C8ACD6"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        FontSize="16" />
                                    <Button
                                        Content="→"
                                        ToolTipService.ToolTip="Open"
                                        Command="{Binding ElementName=RootControl, Path=ViewModel.OpenConversationCommand}"
                                        CommandParameter="{x:Bind Id}"
                                        Background="#433D8B"
                                        Foreground="#C8ACD6"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        FontSize="16" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <StackPanel.Visibility>
                    <Binding
                        ElementName="RootControl"
                        Path="ViewModel.Conversations.Count"
                        Converter="{StaticResource BoolToVisibility}"
                        ConverterParameter="Invert" />
                </StackPanel.Visibility>
                <TextBlock
                    Text="No conversations yet"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="15"
                    Opacity="0.5"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Start a DM or create a group"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="12"
                    Opacity="0.35"
                    HorizontalAlignment="Center" />
            </StackPanel>

        </Grid>

    </Grid>
</UserControl>
