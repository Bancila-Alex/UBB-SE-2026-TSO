<UserControl
    x:Class="ChatModule.src.views.FriendRequestsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:models="using:ChatModule.Models"
    x:Name="RootControl">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E236C" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Content="←"
                    Command="{x:Bind ViewModel.BackCommand}"
                    Background="Transparent"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    FontSize="18"
                    Padding="0,0,12,0" />
                <TextBlock
                    Grid.Column="1"
                    Text="Friend Requests"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="18"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">

            <!-- Loading Spinner -->
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Foreground="#433D8B"
                Width="40"
                Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <!-- Incoming Requests List -->
            <ListView
                ItemsSource="{x:Bind ViewModel.IncomingRequests, Mode=OneWay}"
                Background="Transparent"
                Padding="8"
                SelectionMode="None"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:User">
                        <Border
                            Background="#2E236C"
                            CornerRadius="6"
                            Padding="12,10"
                            Margin="0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Ellipse
                                    Grid.Column="0"
                                    Width="40"
                                    Height="40"
                                    Fill="#433D8B"
                                    Margin="0,0,10,0" />

                                <!-- Username -->
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{x:Bind Username}"
                                    Foreground="#C8ACD6"
                                    FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                    FontSize="14"
                                    VerticalAlignment="Center" />

                                <!-- Accept / Decline buttons -->
                                <StackPanel
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="6">
                                    <Button
                                        Content="✓"
                                        Command="{Binding ElementName=RootControl, Path=ViewModel.AcceptCommand}"
                                        CommandParameter="{x:Bind Id}"
                                        Background="#433D8B"
                                        Foreground="#C8ACD6"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Width="36"
                                        Height="36"
                                        FontSize="16" />
                                    <Button
                                        Content="✕"
                                        Command="{Binding ElementName=RootControl, Path=ViewModel.DeclineCommand}"
                                        CommandParameter="{x:Bind Id}"
                                        Background="#2E236C"
                                        Foreground="#C8ACD6"
                                        BorderBrush="#433D8B"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Width="36"
                                        Height="36"
                                        FontSize="16" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty State -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <StackPanel.Visibility>
                    <Binding
                        ElementName="RootControl"
                        Path="ViewModel.IncomingRequests.Count"
                        Converter="{StaticResource BoolToVisibility}"
                        ConverterParameter="Invert" />
                </StackPanel.Visibility>
                <TextBlock
                    Text="No pending friend requests"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="15"
                    Opacity="0.6"
                    HorizontalAlignment="Center" />
            </StackPanel>

        </Grid>

        <!-- Load Button (refresh) -->
        <Button
            Grid.Row="2"
            Content="Refresh"
            Command="{x:Bind ViewModel.LoadCommand}"
            Background="#433D8B"
            Foreground="#C8ACD6"
            FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
            BorderThickness="0"
            CornerRadius="4"
            HorizontalAlignment="Stretch"
            Margin="12,8"
            Padding="0,10" />

    </Grid>
</UserControl>
