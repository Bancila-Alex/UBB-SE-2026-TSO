<Window
    x:Class="ChatModule.src.views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Login">

    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBoolean" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Background="#17153B">
        <Border
            Width="440"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#2E236C"
            CornerRadius="10"
            Padding="24">
            <StackPanel Spacing="12">
                <TextBlock
                    Text="Welcome Back"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="24"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="Login to continue"
                    Foreground="#C8ACD6"
                    Opacity="0.8"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <TextBox
                    PlaceholderText="Username"
                    Text="{x:Bind ViewModel.Username, Mode=TwoWay}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="10,6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <PasswordBox
                    x:Name="PasswordBox"
                    PlaceholderText="Password"
                    PasswordChanged="PasswordBox_PasswordChanged"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="10,6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <Button
                    Content="Login"
                    Command="{x:Bind ViewModel.LoginCommand}"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolean}}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="0,10"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3" />

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <HyperlinkButton
                        Content="Forgot password?"
                        Command="{x:Bind ViewModel.ForgotPasswordCommand}"
                        Foreground="#C8ACD6"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                    <HyperlinkButton
                        Content="Sign Up"
                        Command="{x:Bind ViewModel.GoToRegisterCommand}"
                        Foreground="#C8ACD6"
                        FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
                </StackPanel>

                <TextBlock
                    Foreground="#FF8A8A"
                    Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibility}}"
                    TextWrapping="Wrap"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />

                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    Width="30"
                    Height="30"
                    Foreground="#C8ACD6"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
