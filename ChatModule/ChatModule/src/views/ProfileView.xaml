<UserControl
    x:Class="ChatModule.src.views.ProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    x:Name="RootControl">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Border
            Width="560"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#2E236C"
            CornerRadius="10"
            Padding="22"
            Visibility="{x:Bind ViewModel.IsOwnProfile, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

            <StackPanel Spacing="14">
                <TextBlock
                    Text="My Profile"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="24"
                    FontWeight="SemiBold" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,16,0">
                        <Ellipse Width="84" Height="84" Fill="#433D8B" />
                        <TextBlock
                            Text="{x:Bind ViewModel.User.Username, Mode=OneWay}"
                            Foreground="#C8ACD6"
                            FontSize="0.1"
                            Opacity="0" />
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <TextBlock
                            Text="{x:Bind ViewModel.User.Username, Mode=OneWay}"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                            FontSize="18"
                            FontWeight="SemiBold" />

                        <Button
                            Content="Upload Avatar"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            HorizontalAlignment="Left"
                            Padding="12,6" />
                    </StackPanel>
                </Grid>

                <TextBlock
                    Text="Bio"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    FontWeight="SemiBold" />

                <TextBox
                    Text="{x:Bind ViewModel.EditBio, Mode=TwoWay}"
                    PlaceholderText="Tell people about you"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    MinHeight="92"
                    Padding="10,8" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock
                            Text="Status"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                            FontSize="14"
                            FontWeight="SemiBold" />

                        <ComboBox
                            ItemsSource="{x:Bind ViewModel.AvailableStatuses, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock
                            Text="Birthday"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                            FontSize="14"
                            FontWeight="SemiBold" />

                        <Grid>
                            <DatePicker
                                Date="{x:Bind ViewModel.EditBirthdayOffset, Mode=TwoWay}"
                                Background="#433D8B"
                                Foreground="#C8ACD6"
                                BorderThickness="0"
                                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans" />
                            <TextBlock
                                Text="🎂"
                                FontSize="18"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Visibility="{x:Bind ViewModel.IsBirthdayToday, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <Button
                    Content="Save"
                    Command="{x:Bind ViewModel.SaveProfileCommand}"
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    CornerRadius="4"
                    HorizontalAlignment="Stretch"
                    Padding="0,11"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="15"
                    FontWeight="SemiBold" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
