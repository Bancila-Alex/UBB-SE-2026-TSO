<UserControl
    x:Name="RootControl"
    x:Class="ChatModule.src.views.MemberPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:models="using:ChatModule.Models">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2E236C" Padding="16,12">
            <TextBlock
                Text="Members"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                FontSize="18"
                FontWeight="SemiBold" />
        </Border>

        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Members, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedMember, Mode=TwoWay}"
            Background="Transparent"
            Padding="8"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Participant">
                    <Border
                        Background="#2E236C"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,2">
                        <TextBlock
                            Text="{x:Bind UserId}"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                            FontSize="14" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Background="#2E236C" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock
                    Text="Add Member"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    FontWeight="SemiBold" />

                <TextBox
                    Text="{x:Bind ViewModel.AddMemberQuery, Mode=TwoWay}"
                    PlaceholderText="Search by username..."
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="13"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="10,6" />

                <ListBox
                    ItemsSource="{x:Bind ViewModel.AddMemberResults, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedAddMember, Mode=TwoWay}"
                    Background="#17153B"
                    BorderThickness="0"
                    MaxHeight="160">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:User">
                            <StackPanel Orientation="Horizontal" Spacing="8" Padding="6,4">
                                <Ellipse Width="28" Height="28" Fill="#433D8B" />
                                <TextBlock
                                    Text="{x:Bind Username}"
                                    Foreground="#C8ACD6"
                                    FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                    FontSize="13"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Content="Ban"
                            Command="{x:Bind ViewModel.BanMemberCommand}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                        <Button
                            Content="Unban"
                            Command="{x:Bind ViewModel.UnbanMemberCommand}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                        <Button
                            Content="Timeout"
                            Command="{x:Bind ViewModel.TimeoutMemberCommand}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Content="Remove Timeout"
                            Command="{x:Bind ViewModel.RemoveTimeoutCommand}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                        <Button
                            Content="Promote"
                            Command="{x:Bind ViewModel.PromoteCommand}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                        <Button
                            Content="Demote"
                            Command="{x:Bind ViewModel.DemoteCommand}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Content="Add Selected"
                        Command="{x:Bind ViewModel.AddMemberCommand}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="12,6" />
                    <Button
                        Content="View Profile"
                        Command="{x:Bind ViewModel.ViewProfileCommand}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="12,6" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
