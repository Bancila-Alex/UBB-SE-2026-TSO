<UserControl
    x:Name="RootControl"
    x:Class="ChatModule.src.views.MemberPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:models="using:ChatModule.Models">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2E236C" Padding="16,12">
            <TextBlock
                Text="Members"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                FontSize="18"
                FontWeight="SemiBold" />
        </Border>

        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Members, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedMember, Mode=TwoWay}"
            Background="Transparent"
            Padding="8"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Participant">
                    <Border
                        Background="#2E236C"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Text="{x:Bind UserId}"
                                Foreground="#C8ACD6"
                                FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                FontSize="14" />

                            <StackPanel
                                Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="6"
                                Margin="0,8,0,0"
                                Visibility="{Binding ElementName=RootControl, Path=ViewModel.IsAdmin, Converter={StaticResource BoolToVisibility}}">
                                <Button
                                    Content="Promote"
                                    Command="{Binding ElementName=RootControl, Path=ViewModel.PromoteCommand}"
                                    CommandParameter="{x:Bind UserId}"
                                    Background="#433D8B"
                                    Foreground="#C8ACD6"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="10,4" />
                                <Button
                                    Content="Demote"
                                    Command="{Binding ElementName=RootControl, Path=ViewModel.DemoteCommand}"
                                    CommandParameter="{x:Bind UserId}"
                                    Background="#433D8B"
                                    Foreground="#C8ACD6"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="10,4" />
                                <Button
                                    Content="Timeout"
                                    Command="{Binding ElementName=RootControl, Path=ViewModel.TimeoutMemberCommand}"
                                    CommandParameter="{x:Bind UserId}"
                                    Background="#433D8B"
                                    Foreground="#C8ACD6"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="10,4" />
                                <Button
                                    Content="Ban"
                                    Command="{Binding ElementName=RootControl, Path=ViewModel.BanMemberCommand}"
                                    CommandParameter="{x:Bind UserId}"
                                    Background="#433D8B"
                                    Foreground="#C8ACD6"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="10,4" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border
            Grid.Row="2"
            Background="#2E236C"
            Padding="12"
            Margin="8,0,8,8"
            Visibility="{x:Bind ViewModel.IsAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Spacing="8">
                <TextBlock
                    Text="Banned Members"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    FontWeight="SemiBold" />

                <ListView
                    ItemsSource="{x:Bind ViewModel.BannedMembers, Mode=OneWay}"
                    Background="Transparent"
                    Padding="0"
                    SelectionMode="None"
                    MaxHeight="180">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Participant">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    Text="{x:Bind UserId}"
                                    Foreground="#C8ACD6"
                                    FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                    FontSize="13"
                                    VerticalAlignment="Center" />

                                <Button
                                    Grid.Column="1"
                                    Content="Unban"
                                    Command="{Binding ElementName=RootControl, Path=ViewModel.UnbanMemberCommand}"
                                    CommandParameter="{x:Bind UserId}"
                                    Background="#433D8B"
                                    Foreground="#C8ACD6"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="10,4" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="#2E236C" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock
                    Text="Add Member"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    FontWeight="SemiBold" />

                <TextBox
                    Text="{x:Bind ViewModel.AddMemberQuery, Mode=TwoWay}"
                    PlaceholderText="Search by username..."
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="13"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="10,6" />

                <ListBox
                    ItemsSource="{x:Bind ViewModel.AddMemberResults, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedAddMember, Mode=TwoWay}"
                    Background="#17153B"
                    BorderThickness="0"
                    MaxHeight="160">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:User">
                            <StackPanel Orientation="Horizontal" Spacing="8" Padding="6,4">
                                <Ellipse Width="28" Height="28" Fill="#433D8B" />
                                <TextBlock
                                    Text="{x:Bind Username}"
                                    Foreground="#C8ACD6"
                                    FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                    FontSize="13"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IsAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Content="Ban"
                            Command="{x:Bind ViewModel.BanMemberCommand}"
                            CommandParameter="{x:Bind ViewModel.SelectedMember.UserId, Mode=OneWay}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                        <Button
                            Content="Unban"
                            Command="{x:Bind ViewModel.UnbanMemberCommand}"
                            CommandParameter="{x:Bind ViewModel.SelectedMember.UserId, Mode=OneWay}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                        <Button
                            Content="Timeout"
                            Command="{x:Bind ViewModel.TimeoutMemberCommand}"
                            CommandParameter="{x:Bind ViewModel.SelectedMember.UserId, Mode=OneWay}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Content="Remove Timeout"
                            Command="{x:Bind ViewModel.RemoveTimeoutCommand}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                        <Button
                            Content="Promote"
                            Command="{x:Bind ViewModel.PromoteCommand}"
                            CommandParameter="{x:Bind ViewModel.SelectedMember.UserId, Mode=OneWay}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                        <Button
                            Content="Demote"
                            Command="{x:Bind ViewModel.DemoteCommand}"
                            CommandParameter="{x:Bind ViewModel.SelectedMember.UserId, Mode=OneWay}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="12,6" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Content="Add Selected"
                        Command="{x:Bind ViewModel.AddMemberCommand}"
                        Visibility="{x:Bind ViewModel.SelectedAddMember, Mode=OneWay, Converter={StaticResource NullToVisibility}}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="12,6" />
                    <Button
                        Content="View Profile"
                        Command="{x:Bind ViewModel.ViewProfileCommand}"
                        Visibility="{x:Bind ViewModel.SelectedAddMember, Mode=OneWay, Converter={StaticResource NullToVisibility}}"
                        Background="#433D8B"
                        Foreground="#C8ACD6"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="12,6" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
