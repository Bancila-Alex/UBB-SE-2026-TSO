<UserControl
    x:Class="ChatModule.src.views.MemberPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:models="using:ChatModule.Models">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E236C" Padding="16,12">
            <TextBlock
                Text="Members"
                Foreground="#C8ACD6"
                FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                FontSize="18"
                FontWeight="SemiBold" />
        </Border>

        <!-- Members List -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Members, Mode=OneWay}"
            Background="Transparent"
            Padding="8"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Participant">
                    <Border
                        Background="#2E236C"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,2">
                        <TextBlock
                            Text="{x:Bind UserId}"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                            FontSize="14" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Add Member Section -->
        <Border Grid.Row="2" Background="#2E236C" Padding="12">
            <StackPanel Spacing="8">

                <TextBlock
                    Text="Add Member"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="14"
                    FontWeight="SemiBold" />

                <!-- Search TextBox -->
                <TextBox
                    Text="{x:Bind ViewModel.AddMemberQuery, Mode=TwoWay}"
                    PlaceholderText="Search by username..."
                    Background="#433D8B"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                    FontSize="13"
                    BorderThickness="0"
                    CornerRadius="4"
                    Padding="10,6" />

                <!-- Search Results -->
                <ListBox
                    ItemsSource="{x:Bind ViewModel.AddMemberResults, Mode=OneWay}"
                    Background="#17153B"
                    BorderThickness="0"
                    MaxHeight="160">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:User">
                            <Button
                                Command="{Binding ElementName=RootControl, Path=ViewModel.AddMemberCommand}"
                                CommandParameter="{x:Bind Id}"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="6,4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="28" Height="28" Fill="#433D8B" />
                                    <TextBlock
                                        Text="{x:Bind Username}"
                                        Foreground="#C8ACD6"
                                        FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                        FontSize="13"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
