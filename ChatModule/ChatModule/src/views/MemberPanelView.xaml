<UserControl
    x:Name="RootControl"
    x:Class="ChatModule.src.views.MemberPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ChatModule.src.views.Converters"
    xmlns:models="using:ChatModule.Models"
    xmlns:vm="using:ChatModule.src.view_models">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Background="#17153B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header (always visible) -->
        <Border Grid.Row="0" Background="#2E236C" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Text="Members"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="18"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />
                <Button
                    Grid.Column="1"
                    Content="{x:Bind ViewModel.TogglePanelIcon, Mode=OneWay}"
                    Command="{x:Bind ViewModel.TogglePanelCommand}"
                    Background="Transparent"
                    Foreground="#C8ACD6"
                    BorderThickness="0"
                    FontSize="16"
                    Padding="8,4" />
            </Grid>
        </Border>

        <!-- Collapsible panel -->
        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            Visibility="{x:Bind ViewModel.IsPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Spacing="0">

                <!-- Loading indicator -->
                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    Foreground="#433D8B"
                    Width="32"
                    Height="32"
                    Margin="0,12"
                    HorizontalAlignment="Center" />

                <!-- Active Members Section -->
                <TextBlock
                    Text="ACTIVE MEMBERS"
                    Foreground="#C8ACD6"
                    FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Opacity="0.6"
                    Margin="12,10,12,4" />

                <ListView
                    ItemsSource="{x:Bind ViewModel.Members, Mode=OneWay}"
                    Background="Transparent"
                    Padding="6,0"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MemberDisplayItem">
                            <Border Background="#2E236C" CornerRadius="6" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Grid Grid.Column="0" Width="36" Height="36" Margin="0,0,10,0">
                                        <Ellipse Fill="#433D8B" />
                                        <Image
                                            Source="{x:Bind AvatarUrl}"
                                            Stretch="UniformToFill"
                                            Visibility="{x:Bind AvatarUrl, Converter={StaticResource NullToVisibility}}" />
                                    </Grid>

                                    <!-- Username + status + role -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                        <TextBlock
                                            Text="{x:Bind Username}"
                                            Foreground="#C8ACD6"
                                            FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                            FontSize="14" />
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <Ellipse
                                                Width="10"
                                                Height="10"
                                                Fill="{x:Bind GetStatusBrush()}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Text="{x:Bind RoleLabel}"
                                                Foreground="#C8ACD6"
                                                FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                                FontSize="11"
                                                Opacity="0.7"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Admin action buttons -->
                                    <StackPanel
                                        Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding ElementName=RootControl, Path=ViewModel.IsAdmin, Converter={StaticResource BoolToVisibility}}">
                                        <Button
                                            Content="↑"
                                            ToolTipService.ToolTip="Promote to Admin"
                                            Command="{Binding ElementName=RootControl, Path=ViewModel.PromoteCommand}"
                                            CommandParameter="{x:Bind UserId}"
                                            Visibility="{x:Bind IsMemberRole, Converter={StaticResource BoolToVisibility}}"
                                            Background="#433D8B"
                                            Foreground="#C8ACD6"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            FontSize="14" />
                                        <Button
                                            Content="↓"
                                            ToolTipService.ToolTip="Demote to Member"
                                            Command="{Binding ElementName=RootControl, Path=ViewModel.DemoteCommand}"
                                            CommandParameter="{x:Bind UserId}"
                                            Visibility="{x:Bind IsAdminRole, Converter={StaticResource BoolToVisibility}}"
                                            Background="#433D8B"
                                            Foreground="#C8ACD6"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            FontSize="14" />
                                        <Button
                                            Content="⏱"
                                            ToolTipService.ToolTip="Timeout (1 hour)"
                                            Command="{Binding ElementName=RootControl, Path=ViewModel.TimeoutMemberCommand}"
                                            CommandParameter="{x:Bind UserId}"
                                            Visibility="{x:Bind IsMemberRole, Converter={StaticResource BoolToVisibility}}"
                                            Background="#433D8B"
                                            Foreground="#C8ACD6"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            FontSize="14" />
                                        <Button
                                            Content="✕⏱"
                                            ToolTipService.ToolTip="Remove Timeout"
                                            Command="{Binding ElementName=RootControl, Path=ViewModel.RemoveTimeoutCommand}"
                                            CommandParameter="{x:Bind UserId}"
                                            Visibility="{x:Bind HasTimeout, Converter={StaticResource BoolToVisibility}}"
                                            Background="#433D8B"
                                            Foreground="#C8ACD6"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            FontSize="11" />
                                        <Button
                                            Content="🚫"
                                            ToolTipService.ToolTip="Ban Member"
                                            Command="{Binding ElementName=RootControl, Path=ViewModel.BanMemberCommand}"
                                            CommandParameter="{x:Bind UserId}"
                                            Background="#433D8B"
                                            Foreground="#C8ACD6"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            FontSize="14" />
                                        <Button
                                            Content="👤"
                                            ToolTipService.ToolTip="View Profile"
                                            Command="{Binding ElementName=RootControl, Path=ViewModel.ViewProfileCommand}"
                                            CommandParameter="{x:Bind UserId}"
                                            Background="Transparent"
                                            Foreground="#C8ACD6"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            FontSize="14" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Banned Members Section (admin only) -->
                <StackPanel
                    Margin="0,8,0,0"
                    Visibility="{x:Bind ViewModel.IsAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock
                        Text="BANNED MEMBERS"
                        Foreground="#C8ACD6"
                        FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Opacity="0.6"
                        Margin="12,4,12,4" />
                    <ListView
                        ItemsSource="{x:Bind ViewModel.BannedMembers, Mode=OneWay}"
                        Background="Transparent"
                        Padding="6,0"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MemberDisplayItem">
                                <Border Background="#2E236C" CornerRadius="6" Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar placeholder -->
                                        <Ellipse
                                            Grid.Column="0"
                                            Width="36"
                                            Height="36"
                                            Fill="#433D8B"
                                            Opacity="0.5"
                                            Margin="0,0,10,0" />

                                        <!-- Username -->
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind Username}"
                                            Foreground="#C8ACD6"
                                            FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                            FontSize="14"
                                            Opacity="0.6"
                                            VerticalAlignment="Center" />

                                        <!-- Unban button -->
                                        <Button
                                            Grid.Column="2"
                                            Content="Unban"
                                            Command="{Binding ElementName=RootControl, Path=ViewModel.UnbanMemberCommand}"
                                            CommandParameter="{x:Bind UserId}"
                                            Background="#433D8B"
                                            Foreground="#C8ACD6"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Padding="10,4"
                                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                                            FontSize="12" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Add Member Section (admin only) -->
                <Border
                    Margin="6,10,6,8"
                    Background="#2E236C"
                    CornerRadius="8"
                    Padding="12"
                    Visibility="{x:Bind ViewModel.IsAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Add Member"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/SourceSans3-Regular.ttf#Source Sans 3"
                            FontSize="14"
                            FontWeight="SemiBold" />

                        <TextBox
                            Text="{x:Bind ViewModel.AddMemberQuery, Mode=TwoWay}"
                            PlaceholderText="Search by username..."
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                            FontSize="13"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="10,6" />

                        <!-- Search Results -->
                        <ListBox
                            ItemsSource="{x:Bind ViewModel.AddMemberResults, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedAddMember, Mode=TwoWay}"
                            Background="#17153B"
                            BorderThickness="0"
                            MaxHeight="160"
                            Visibility="{x:Bind ViewModel.AddMemberResults.Count, Mode=OneWay, Converter={StaticResource NullToVisibility}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:User">
                                    <Grid Padding="4,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse
                                            Grid.Column="0"
                                            Width="28"
                                            Height="28"
                                            Fill="#433D8B"
                                            Margin="0,0,8,0" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind Username}"
                                            Foreground="#C8ACD6"
                                            FontFamily="ms-appx:///Assets/Fonts/Ubuntu-Regular.ttf#Ubuntu"
                                            FontSize="13"
                                            VerticalAlignment="Center" />
                                        <Button
                                            Grid.Column="2"
                                            Content="View"
                                            Command="{Binding ElementName=RootControl, Path=ViewModel.ViewProfileCommand}"
                                            CommandParameter="{x:Bind Id}"
                                            Background="Transparent"
                                            Foreground="#C8ACD6"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Add Selected button -->
                        <Button
                            Content="Add Selected"
                            Command="{x:Bind ViewModel.AddMemberCommand}"
                            Visibility="{x:Bind ViewModel.SelectedAddMember, Mode=OneWay, Converter={StaticResource NullToVisibility}}"
                            Background="#433D8B"
                            Foreground="#C8ACD6"
                            FontFamily="ms-appx:///Assets/Fonts/NotoSans-Regular.ttf#Noto Sans"
                            BorderThickness="0"
                            CornerRadius="4"
                            HorizontalAlignment="Stretch"
                            Padding="12,6" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
